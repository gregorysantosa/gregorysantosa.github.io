---
import { getCollection } from "astro:content";
import SiteLayout from "../../components/SiteLayout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { formatLongDate } from "../../lib/format";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((item) => ({
    params: { slug: item.data.urlPath },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const { title, date, tags } = item.data;
---

<SiteLayout title={title} backLink={{ label: "Blog posts", href: "/year-archive/" }}>
  <AuthorCard slot="sidebar" />
  <article class="doc doc-panel">
    <header class="doc__head">
      <h1 class="doc__title">{title}</h1>
      <p class="doc__meta">{formatLongDate(date)}</p>
      {
        tags && tags.length > 0 && (
          <ul class="doc__tags">
            {tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose doc__body">
      <Content />
    </div>
  </article>
</SiteLayout>

<style>
  .doc__head {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .doc__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.1rem);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .doc__meta {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .doc__tags {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .doc__tags li {
    font-size: 0.8rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--text);
  }
</style>
