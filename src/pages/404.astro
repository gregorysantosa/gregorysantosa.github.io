---
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout title="Page not found">
  <div class="not-found doc-panel">
    <p class="not-found__eyebrow">Error</p>
    <h1 class="not-found__title">404</h1>
    <p class="not-found__text">This page does not exist or has moved.</p>
    <a class="not-found__btn motion-safe-transition" href="/">Back home</a>
  </div>
</SiteLayout>

<style>
  .not-found {
    text-align: center;
    padding: 2.5rem 1.5rem 2.75rem;
    max-width: 26rem;
    margin: 0 auto;
  }
  .not-found__eyebrow {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .not-found__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 4.5rem);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .not-found__text {
    color: var(--text-muted);
    margin: 1rem 0 1.5rem;
    font-size: 1.02rem;
  }
  .not-found__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 1.35rem;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: 999px;
    text-decoration: none;
    background: var(--accent);
    color: #fff;
  }
  @media (prefers-color-scheme: dark) {
    .not-found__btn {
      color: #042f2c;
    }
  }
  .not-found__btn:hover {
    filter: brightness(1.06);
    box-shadow: 0 6px 20px var(--accent-soft);
  }
</style>
