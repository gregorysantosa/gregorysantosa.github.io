---
import { getCollection } from "astro:content";
import SiteLayout from "../../components/SiteLayout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { formatExperienceRange } from "../../lib/format";

export async function getStaticPaths() {
  const talks = await getCollection("talks");
  return talks.map((item) => ({
    params: { slug: item.data.urlPath },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const { title, type, venue, location, startDate, endDate } = item.data;
---

<SiteLayout
  title={title}
  backLink={{ label: "All experience", href: "/experiences/" }}
>
  <AuthorCard slot="sidebar" />
  <article class="doc doc-panel">
    <header class="doc__head">
      <h1 class="doc__title">{title}</h1>
      <p class="doc__meta">
        {type} · {venue} · {location}
      </p>
      <p class="doc__dates">
        {formatExperienceRange(startDate, endDate)}
      </p>
    </header>
    <div class="prose doc__body">
      <Content />
    </div>
  </article>
</SiteLayout>

<style>
  .doc__head {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .doc__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.1rem);
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }
  .doc__meta,
  .doc__dates {
    margin: 0.25rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
