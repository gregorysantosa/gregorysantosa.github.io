---
import { author } from "../site.config";
---

<div class="author-card motion-safe-transition">
  <div class="author-card__avatar-wrap">
    <img
      class="author-card__avatar"
      src={author.avatar}
      width="160"
      height="160"
      alt=""
    />
  </div>
  <h2 class="author-card__name">{author.name}</h2>
  <ul class="author-card__meta">
    <li>{author.location}</li>
    <li>{author.employer}</li>
  </ul>
  <div class="author-card__actions">
    <a class="author-card__btn motion-safe-transition" href={`mailto:${author.email}`}>
      Email
    </a>
    <a
      class="author-card__btn author-card__btn--ghost motion-safe-transition"
      href={`https://github.com/${author.github}`}
    >
      GitHub
    </a>
  </div>
</div>

<style>
  .author-card {
    position: relative;
    background: var(--bg-elevated);
    border-radius: var(--radius-lg);
    padding: 1.35rem 1.25rem 1.25rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .author-card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--accent) 55%, transparent),
      transparent 40%,
      transparent 60%,
      color-mix(in srgb, var(--accent) 25%, transparent)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .author-card__avatar-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    position: relative;
  }
  .author-card__avatar {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--border);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .author-card__name {
    font-family: var(--font-display);
    font-size: 1.28rem;
    font-weight: 600;
    margin: 0 0 0.65rem;
    text-align: center;
    letter-spacing: -0.02em;
    position: relative;
  }
  .author-card__meta {
    list-style: none;
    margin: 0 0 1.1rem;
    padding: 0;
    font-size: 0.86rem;
    color: var(--text-muted);
    line-height: 1.45;
    text-align: center;
    position: relative;
  }
  .author-card__meta li {
    margin: 0.35rem 0;
  }
  .author-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    position: relative;
  }
  .author-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1rem;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: 999px;
    text-decoration: none;
    background: var(--accent);
    color: #fff;
    border: 1px solid transparent;
  }
  @media (prefers-color-scheme: dark) {
    .author-card__btn {
      color: #042f2c;
    }
  }
  .author-card__btn:hover {
    filter: brightness(1.08);
    box-shadow: 0 4px 16px var(--accent-soft);
  }
  .author-card__btn--ghost {
    background: transparent;
    color: var(--accent);
    border-color: var(--border);
  }
  .author-card__btn--ghost:hover {
    background: var(--accent-soft);
    border-color: transparent;
  }
</style>
